generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// =======================
// STOCK
// =======================

model Produit {
  id Int @id @default(autoincrement())

  reference String @unique

  codeBarre String?

  nom String

  categorieId Int?

  categorie Categorie? @relation(fields: [categorieId], references: [id])

  fournisseurId Int?

  fournisseur Fournisseur? @relation(fields: [fournisseurId], references: [id])

  marque String?

  emplacement String?

  prixAchat Float @default(0)

  prixVente Float @default(0)

  quantite Int @default(0)

  seuilAlerte Int @default(5)

  lignesInventaire       InventaireLigne[]
  ajustementsInventaire  InventaireAjustement[]

  mouvements Mouvement[]


  lignesFacture FactureLigne[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Mouvement {
  id Int @id @default(autoincrement())

  produitId Int

  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)

  type String

  quantite Int

  commentaire String?

  createdAt DateTime @default(now())
}



model Fournisseur {
  id Int @id @default(autoincrement())

  nom String

  telephone String?

  email String?

  adresse String?

  contact String?

  produits Produit[]

  createdAt DateTime @default(now())
}

model Categorie {
  id Int @id @default(autoincrement())

  nom String @unique

  description String?

  produits Produit[]

  createdAt DateTime @default(now())
}

// =======================
// CRM
// =======================

model Client {
  id Int @id @default(autoincrement())

  nom String

  entreprise String?

  email String?

  telephone String?

  whatsapp String?

  adresse String?

  ville String?

  pays String?

  siteWeb String?

  secteur String?

  statut String @default("Prospect")

  score Int @default(0)

  notes String?

  activites Activite[]

  opportunites Opportunite[]

  factures Facture[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Activite {
  id Int @id @default(autoincrement())

  titre String

  type String

  description String?

  date DateTime

  statut String @default("A faire")

  priorite String @default("Normale")

  clientId Int

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Opportunite {
  id Int @id @default(autoincrement())

  nom String

  clientId Int?

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  montant Float

  probabilite Int @default(0)

  statut String @default("Prospection")

  factures Facture[]

  createdAt DateTime @default(now())
}

// =======================
// FACTURATION
// =======================

model Facture {
  id Int @id @default(autoincrement())

  numero String @unique

  clientId Int?

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  opportuniteId Int?

  opportunite Opportunite? @relation(fields: [opportuniteId], references: [id], onDelete: SetNull)

  lignes FactureLigne[]

  montant Float

  tva Float @default(20)

  remise Float @default(0)

  statut String @default("Brouillon")

  dateEcheance DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model FactureLigne {
  id Int @id @default(autoincrement())

  factureId Int

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  produitId Int

  produit Produit @relation(fields: [produitId], references: [id])

  quantite Int

  prix Float
}

// =======================
// UTILISATEURS
// =======================

model User {
  id Int @id @default(autoincrement())

  nom String

  email String @unique

  password String

  sessionsResponsable    InventaireSession[]     @relation("SessionResponsable")
  sessionsValidees       InventaireSession[]     @relation("SessionValidateur")
  comptages              InventaireComptage[]
  ajustements            InventaireAjustement[]
  auditsInventaire       InventaireAudit[]

  role String @default("USER")

  actif Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

enum InventaireStatut {
  BROUILLON
  EN_COURS
  A_VALIDER
  VALIDE
  ANNULE
}

model Entrepot {
  id       Int                 @id @default(autoincrement())
  nom      String
  adresse  String?
  sessions InventaireSession[]
}

model InventaireSession {
  id             Int               @id @default(autoincrement())
  nom            String
  reference      String?           @unique
  date           DateTime
  heure          String?
  entrepotId     Int?
  entrepot       Entrepot?         @relation(fields: [entrepotId], references: [id])
  zone           String?
  responsableId  Int?
  responsable    User?             @relation("SessionResponsable", fields: [responsableId], references: [id])
  equipe         String?
  commentaire    String?
  statut         InventaireStatut  @default(BROUILLON)
  doubleComptage Boolean           @default(false)
  signature      String?
  valideLe       DateTime?
  valideParId    Int?
  validePar      User?             @relation("SessionValidateur", fields: [valideParId], references: [id])

  lignes      InventaireLigne[]
  ajustements InventaireAjustement[]
  audits      InventaireAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventaireLigne {
  id           Int      @id @default(autoincrement())
  sessionId    Int
  session      InventaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  produitId    Int
  produit      Produit  @relation(fields: [produitId], references: [id])

  stockSysteme Int
  stockCompte1 Int?
  stockCompte2 Int?
  stockCompte  Int?
  ecart        Int?
  valeurEcart  Float?
  commentaire  String?
  photoUrl     String?

  comptages InventaireComptage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventaireComptage {
  id            Int             @id @default(autoincrement())
  ligneId       Int
  ligne         InventaireLigne @relation(fields: [ligneId], references: [id], onDelete: Cascade)
  numero        Int
  quantite      Int
  compteParId   Int?
  compteParUser User?           @relation(fields: [compteParId], references: [id])
  createdAt     DateTime        @default(now())
}

model InventaireAjustement {
  id            Int      @id @default(autoincrement())
  sessionId     Int
  session       InventaireSession @relation(fields: [sessionId], references: [id])
  produitId     Int
  produit       Produit  @relation(fields: [produitId], references: [id])
  quantite      Int
  ancienStock   Int
  nouveauStock  Int
  motif         String?
  responsableId Int?
  responsable   User?    @relation(fields: [responsableId], references: [id])
  createdAt     DateTime @default(now())
}

model InventaireAudit {
  id             Int      @id @default(autoincrement())
  sessionId      Int?
  session        InventaireSession? @relation(fields: [sessionId], references: [id])
  utilisateurId  Int?
  utilisateur    User?    @relation(fields: [utilisateurId], references: [id])
  action         String
  ancienneValeur String?
  nouvelleValeur String?
  adresseIp      String?
  justification  String?
  createdAt      DateTime @default(now())
}

model InventaireParametres {
  id                    Int      @id @default(autoincrement())
  frequence             String   @default("Mensuelle")
  doubleComptage        Boolean  @default(true)
  toleranceEcart        Float    @default(2)
  validationObligatoire Boolean  @default(true)
  signatureObligatoire  Boolean  @default(true)
  notifications         Boolean  @default(true)
  rappelsAutomatiques   Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}
